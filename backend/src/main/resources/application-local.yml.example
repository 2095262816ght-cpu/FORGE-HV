# 复制为 application-local.yml 后按本机修改（已在 .gitignore）
# 启动时加：--spring.profiles.active=local
# 或设置环境变量 FORGE_DB_USER / FORGE_DB_PASSWORD / FORGE_JWT_SECRET

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/forge_hv?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true&useSSL=false
    username: root
    password: YOUR_MYSQL_PASSWORD

forge:
  jwt:
    secret: ${FORGE_JWT_SECRET:please-change-this-dev-secret-key-32b}
