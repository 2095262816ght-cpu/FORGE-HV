# 默认文本文件统一用 LF 换行符，消除 CRLF 警告
* text=auto eol=lf

# Windows 专用脚本保留 CRLF
*.bat   text eol=crlf
*.cmd   text eol=crlf
*.ps1   text eol=crlf

# 二进制文件，不做换行符转换
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.xlsx  binary
*.xls   binary
*.pth   binary
*.npy   binary
*.pkl   binary
*.zip   binary
